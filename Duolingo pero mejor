/* ---------------------------- ESTADO ---------------------------- */
const MAX_HEARTS = 5;
let state = {
  screen: 'home',          // home | teach | lesson | practice | summary | practiceSummary | gameover
  unitIdx: 0,
  levelIdx: 0,
  qIndex: 0,
  hearts: MAX_HEARTS,
  xp: 0,
  streak: 0,
  completed: {},            // "unitIdx-levelIdx": true
  selected: null,
  answered: false,
  sessionCorrect: 0,
  combo: 0,
  feedbackMsg: '',
  match: null,              // { terms, defs, matched:Set, selTerm, selDef, wrongPair, total }
  practicePool: [],
  practiceUnit: null,       // for labeling questions during practice
};

function isLevelUnlocked(u, l){
  if (u===0 && l===0) return true;
  if (l===0){
    const prevUnit = UNITS[u-1];
    return !!state.completed[`${u-1}-${prevUnit.levels.length-1}`];
  }
  return !!state.completed[`${u}-${l-1}`];
}
function isLevelDone(u,l){ return !!state.completed[`${u}-${l}`]; }
function hasAnyCompleted(){ return Object.keys(state.completed).length > 0; }

function shuffleArr(arr){
  const a = arr.slice();
  for (let i=a.length-1; i>0; i--){
    const j = Math.floor(Math.random()*(i+1));
    [a[i],a[j]] = [a[j],a[i]];
  }
  return a;
}

/* ---------------------------- RENDER ---------------------------- */
const app = document.getElementById('app');

function render(){
  if (state.screen==='home') renderHome();
  else if (state.screen==='teach') renderTeach();
  else if (state.screen==='lesson' || state.screen==='practice') renderQuizScreen();
  else if (state.screen==='summary') renderSummary();
  else if (state.screen==='practiceSummary') renderPracticeSummary();
  else if (state.screen==='gameover') renderGameOver();
}

function heartIconSvg(){
  return `<svg viewBox="0 0 24 24" fill="var(--coral)" stroke="none"><path d="M12 20s-7-4.4-9.5-9C.8 7.3 3 4 6.3 4 8.6 4 10.6 5.3 12 7.2 13.4 5.3 15.4 4 17.7 4 21 4 23.2 7.3 21.5 11c-2.5 4.6-9.5 9-9.5 9z"/></svg>`;
}

function topBar(){
