<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>BioQuest — Aprendé Biología</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">
<style>
  :root{
    --paper:#F6F4EC;
    --paper-line:#E2DCC9;
    --ink:#1E2A1F;
    --ink-soft:#5B6459;
    --leaf:#2E7D4F;
    --leaf-dark:#1D5C37;
    --leaf-pale:#DCEEDF;
    --violet:#6C4FA1;
    --violet-dark:#4E3577;
    --violet-pale:#E7E0F3;
    --coral:#E1552C;
    --coral-dark:#B33F1E;
    --coral-pale:#FBE0D4;
    --amber:#C68A1F;
    --amber-dark:#8F6212;
    --amber-pale:#F5E7C7;
    --teal:#1E7A6B;
    --teal-dark:#125349;
    --teal-pale:#D7ECE8;
    --plum:#8C4A6B;
    --plum-dark:#63304A;
    --plum-pale:#F0DFE8;
    --sky:#2E6DA4;
    --sky-dark:#1F4E78;
    --sky-pale:#DCE9F5;
    --white:#FFFFFF;
    --shadow: 0 4px 0 rgba(30,42,31,0.18);
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:
      linear-gradient(var(--paper-line) 1px, transparent 1px) 0 0/100% 28px,
      var(--paper);
    color:var(--ink);
    font-family:'Space Grotesk', sans-serif;
    min-height:100vh;
    -webkit-font-smoothing:antialiased;
  }
  #app{max-width:480px; margin:0 auto; min-height:100vh; position:relative; padding-bottom:24px;}

  h1,h2,h3{font-family:'Fraunces', serif; margin:0; letter-spacing:-0.01em;}
  .mono{font-family:'JetBrains Mono', monospace;}

  button{font-family:inherit; cursor:pointer; border:none;}
  button:focus-visible, [tabindex]:focus-visible{outline:3px solid var(--amber); outline-offset:2px;}

  /* ---------- Top bar ---------- */
  .topbar{
    display:flex; align-items:center; justify-content:space-between;
    padding:16px 18px 10px;
    position:sticky; top:0; z-index:20;
    background:var(--paper);
    border-bottom:1px solid var(--paper-line);
  }
  .stat{display:flex; align-items:center; gap:6px; font-weight:700; font-size:15px;}
  .stat svg{width:20px; height:20px; flex:none;}

  /* ---------- Home / path screen ---------- */
  .home-header{padding:22px 20px 6px;}
  .home-header .eyebrow{
    font-size:12px; text-transform:uppercase; letter-spacing:0.12em; color:var(--ink-soft); font-weight:600;
  }
  .home-header h1{font-size:26px; margin-top:4px; color:var(--leaf-dark);}
  .home-header p.lead{font-size:13.5px; color:var(--ink-soft); margin-top:6px; max-width:38ch; line-height:1.4;}

  /* ---------- Practice / Repaso card ---------- */
  .practice-card{
    margin:18px 20px 4px; padding:16px 18px; border-radius:14px;
    background:linear-gradient(135deg,#4A3D63,#241D33); color:var(--white);
    box-shadow:var(--shadow);
    display:flex; align-items:center; justify-content:space-between; gap:12px;
  }
  .practice-card .txt h3{font-size:15px; margin-bottom:3px;}
  .practice-card .txt p{font-size:11.5px; opacity:0.82; margin:0; line-height:1.4;}
  .practice-card button{
    background:var(--white); color:var(--violet-dark); font-weight:700; font-size:12.5px;
    padding:10px 16px; border-radius:9px; flex:none; box-shadow:0 3px 0 rgba(0,0,0,0.2);
  }
  .practice-card button:active{transform:translateY(2px); box-shadow:none;}
  .practice-card .icon-wrap{width:34px; height:34px; flex:none; opacity:0.9;}
  .practice-card .icon-wrap svg{width:100%; height:100%; stroke:var(--white); fill:none; stroke-width:1.6;}
  .practice-locked{
    margin:18px 20px 4px; padding:14px 18px; border-radius:14px;
    border:2px dashed var(--paper-line); color:var(--ink-soft); font-size:12.5px; text-align:center; line-height:1.4;
  }

  .unit-block{margin:26px 0 6px;}
  .unit-header{
    margin:0 20px 22px;
    padding:14px 18px;
    border-radius:14px;
    color:var(--white);
    display:flex; align-items:center; justify-content:space-between;
    box-shadow:var(--shadow);
  }
  .unit-header h2{font-size:18px;}
  .unit-header .unit-sub{font-size:12px; opacity:0.85; margin-top:2px; font-weight:500;}

  .path{position:relative; padding:6px 0 10px;}

  .node-row{display:flex; justify-content:center; margin:2px 0;}
  .node-row.offset-left{justify-content:flex-start; padding-left:18%;}
  .node-row.offset-right{justify-content:flex-end; padding-right:18%;}

  .node{
    width:74px; height:74px;
    display:flex; align-items:center; justify-content:center;
    position:relative;
    margin:10px 0;
  }
  .node button.hex{
    width:100%; height:100%;
    clip-path: polygon(50% 0%, 95% 25%, 95% 75%, 50% 100%, 5% 75%, 5% 25%);
    display:flex; align-items:center; justify-content:center;
    position:relative;
    transition: transform .12s ease;
  }
  .node button.hex:active{transform:translateY(3px);}
  .node.locked button.hex{background:#D8D3C4; box-shadow:0 4px 0 #BEB8A4; color:#8B8570;}
  .node.locked button.hex svg{stroke:#8B8570;}
  .node.current button.hex{animation:pulse 1.8s ease-in-out infinite;}
  .node-label{
    position:absolute; top:80px; left:50%; transform:translateX(-50%);
    font-size:11px; font-weight:600; color:var(--ink-soft); width:110px; text-align:center; line-height:1.25;
  }
  @keyframes pulse{
    0%,100%{ box-shadow:0 4px 0 rgba(30,42,31,0.18), 0 0 0 0 rgba(46,125,79,0.35); }
    50%{ box-shadow:0 4px 0 rgba(30,42,31,0.18), 0 0 0 10px rgba(46,125,79,0); }
  }
  .node svg.icon{width:30px; height:30px; fill:none; stroke:var(--white); stroke-width:1.8;}
  .node .check{position:absolute; bottom:-4px; right:-2px; width:22px; height:22px; background:var(--amber); border-radius:50%; display:flex; align-items:center; justify-content:center; box-shadow:0 2px 0 rgba(0,0,0,0.15);}
  .node .check svg{width:13px; height:13px; stroke:var(--white); stroke-width:3; fill:none;}

  /* ---------- Shared lesson/teach header ---------- */
  .lesson-header{
    display:flex; align-items:center; gap:10px; padding:14px 18px;
    position:sticky; top:0; background:var(--paper); z-index:20; border-bottom:1px solid var(--paper-line);
  }
  .exit-btn{background:none; color:var(--ink-soft); font-size:22px; line-height:1; padding:4px;}
  .progress-track{flex:1; height:12px; background:#E2DCC9; border-radius:8px; overflow:hidden;}
  .progress-fill{height:100%; background:var(--leaf); border-radius:8px; transition:width .35s ease;}
  .progress-fill.practice-fill{background:var(--violet);}
  .hearts-mini{display:flex; align-items:center; gap:4px; font-weight:700; color:var(--coral-dark); font-size:14px; flex:none;}
  .hearts-mini svg{width:18px; height:18px;}
  .teach-heading-line{flex:1; font-weight:700; font-size:13.5px; color:var(--ink-soft);}
  .combo-badge{
    display:flex; align-items:center; gap:3px; background:var(--amber-pale); color:var(--amber-dark);
    font-weight:700; font-size:12px; padding:4px 8px; border-radius:20px; flex:none; white-space:nowrap;
  }

  /* ---------- Teach screen ---------- */
  .teach-wrap{padding:22px 20px 130px;}
  .q-kicker{font-size:12px; text-transform:uppercase; letter-spacing:0.1em; color:var(--ink-soft); font-weight:700; margin-bottom:10px;}
  .teach-title{font-size:23px; margin-bottom:18px;}
  .concept{
    background:var(--white); border:2px solid var(--paper-line); border-radius:14px;
    padding:16px 18px; margin-bottom:14px; box-shadow:0 3px 0 var(--paper-line);
  }
  .concept h3{font-size:15.5px; margin-bottom:8px;}
  .concept p{font-size:14px; line-height:1.55; color:var(--ink); margin:0 0 8px;}
  .concept ul{margin:0; padding-left:18px; font-size:13.5px; color:var(--ink-soft); line-height:1.5;}
  .concept ul li{margin-bottom:4px;}
  .concept ul li b{color:var(--ink);}

  .question-wrap{padding:28px 22px 130px;}
  .q-text{font-family:'Fraunces', serif; font-size:22px; font-weight:600; line-height:1.35; color:var(--ink); margin-bottom:22px;}
  .q-text .blank{text-decoration:underline; text-decoration-style:dashed; text-decoration-color:var(--leaf); text-underline-offset:5px; color:var(--leaf-dark);}
  .q-type-tag{display:inline-block; font-size:10.5px; text-transform:uppercase; letter-spacing:0.08em; font-weight:700; color:var(--violet-dark); background:var(--violet-pale); padding:3px 9px; border-radius:20px; margin-bottom:10px;}

  .options{display:flex; flex-direction:column; gap:12px;}
  .option{
    text-align:left; background:var(--white); border:2px solid var(--paper-line);
    border-radius:12px; padding:15px 16px; font-size:16px; font-weight:600; color:var(--ink);
    box-shadow:0 3px 0 var(--paper-line);
    display:flex; align-items:center; gap:12px;
    transition: border-color .12s, background .12s, transform .06s;
    width:100%;
  }
  .option:active{transform:translateY(2px);}
  .option .letter{
    width:26px; height:26px; border-radius:7px; background:var(--paper); border:2px solid var(--paper-line);
    display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:700; color:var(--ink-soft); flex:none;
  }
  .option.selected{border-color:var(--leaf); background:var(--leaf-pale);}
  .option.selected .letter{background:var(--leaf); border-color:var(--leaf); color:var(--white);}
  .option.correct{border-color:var(--leaf); background:var(--leaf-pale);}
  .option.correct .letter{background:var(--leaf); border-color:var(--leaf); color:var(--white);}
  .option.wrong{border-color:var(--coral); background:var(--coral-pale);}
  .option.wrong .letter{background:var(--coral); border-color:var(--coral); color:var(--white);}
  .option[disabled]{cursor:default;}

  .tf-row{display:flex; gap:12px;}
  .tf-row .option{flex:1; justify-content:center; text-align:center;}

  /* ---------- Match (relacionar) exercise ---------- */
  .match-hint{font-size:12.5px; color:var(--ink-soft); margin:-10px 0 16px; line-height:1.4;}
  .match-wrap{display:flex; gap:10px;}
  .match-col{flex:1; display:flex; flex-direction:column; gap:9px;}
  .match-item{
    background:var(--white); border:2px solid var(--paper-line); border-radius:10px;
    padding:12px 10px; font-size:12.5px; font-weight:600; text-align:center; line-height:1.3;
    box-shadow:0 3px 0 var(--paper-line); min-height:48px; display:flex; align-items:center; justify-content:center;
    transition:transform .1s;
  }
  .match-item:active{transform:translateY(2px);}
  .match-item.selected{border-color:var(--sky); background:var(--sky-pale); color:var(--sky-dark);}
  .match-item.matched{border-color:var(--leaf); background:var(--leaf-pale); color:var(--leaf-dark); opacity:0.55; box-shadow:none;}
  .match-item.wrong{border-color:var(--coral); background:var(--coral-pale); animation:shake .3s;}
  .match-item[disabled]{cursor:default;}
  @keyframes shake{0%,100%{transform:translateX(0);}25%{transform:translateX(-5px);}75%{transform:translateX(5px);}}

  /* ---------- Bottom action bar ---------- */
  .action-bar{
    position:fixed; bottom:0; left:0; right:0;
    max-width:480px; margin:0 auto;
    background:var(--paper); border-top:1px solid var(--paper-line);
    padding:14px 22px 20px;
    z-index:30;
  }
  .action-bar.state-correct{background:var(--leaf-pale); border-top-color:var(--leaf);}
  .action-bar.state-wrong{background:var(--coral-pale); border-top-color:var(--coral);}
  .feedback-line{display:flex; align-items:center; gap:8px; font-weight:700; margin-bottom:6px; font-size:15px; flex-wrap:wrap;}
  .feedback-line.correct{color:var(--leaf-dark);}
  .feedback-line.wrong{color:var(--coral-dark);}
  .feedback-line .mini-combo{font-size:12px; font-weight:700; color:var(--amber-dark); background:var(--amber-pale); padding:2px 8px; border-radius:20px;}
  .feedback-explain{font-size:12.5px; color:var(--ink-soft); margin:0 0 10px; line-height:1.4;}
  .btn-primary{
    width:100%; padding:15px; border-radius:12px; font-size:15px; font-weight:700;
    letter-spacing:0.04em; text-transform:uppercase; background:#CFC9B6; color:#8B8570; box-shadow:0 4px 0 #BEB8A4;
  }
  .btn-primary.ready{background:var(--leaf); color:var(--white); box-shadow:0 4px 0 var(--leaf-dark);}
  .btn-primary.ready:active{transform:translateY(3px); box-shadow:0 1px 0 var(--leaf-dark);}
  .btn-primary.wrong-state{background:var(--coral); color:var(--white); box-shadow:0 4px 0 var(--coral-dark);}
  .btn-primary.wrong-state:active{transform:translateY(3px); box-shadow:0 1px 0 var(--coral-dark);}
  .btn-primary.practice-state{background:var(--violet); color:var(--white); box-shadow:0 4px 0 var(--violet-dark);}
  .btn-primary.practice-state:active{transform:translateY(3px); box-shadow:0 1px 0 var(--violet-dark);}

  /* ---------- Summary / gameover screens ---------- */
  .center-screen{min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:32px 28px; text-align:center;}
  .center-screen .badge{width:120px; height:120px; margin-bottom:22px;}
  .center-screen h1{font-size:28px; margin-bottom:8px;}
  .center-screen p{color:var(--ink-soft); font-size:15px; margin-bottom:26px; max-width:320px; line-height:1.5;}
  .summary-stats{display:flex; gap:14px; margin-bottom:30px;}
  .summary-stat{background:var(--white); border:2px solid var(--paper-line); border-radius:12px; padding:14px 20px; min-width:96px;}
  .summary-stat .num{font-family:'JetBrains Mono', monospace; font-size:22px; font-weight:700; color:var(--leaf-dark);}
  .summary-stat .lbl{font-size:11px; color:var(--ink-soft); text-transform:uppercase; letter-spacing:0.06em; margin-top:2px; font-weight:600;}
  .wide-btn{width:100%; max-width:320px; padding:16px; border-radius:12px; background:var(--leaf); color:var(--white); font-weight:700; font-size:15px; text-transform:uppercase; letter-spacing:0.04em; box-shadow:0 4px 0 var(--leaf-dark);}
  .wide-btn:active{transform:translateY(3px); box-shadow:0 1px 0 var(--leaf-dark);}
  .wide-btn.secondary{background:transparent; color:var(--ink-soft); box-shadow:none; margin-top:12px; text-transform:none; font-weight:600; letter-spacing:0;}

  .sr-only{position:absolute; width:1px; height:1px; overflow:hidden; clip:rect(0 0 0 0);}
</style>
</head>
<body>
<div id="app"></div>

<script>
/* =========================================================================
   PERSISTENCIA
   Usa el almacenamiento persistente de artefactos (window.storage) para
   guardar XP, racha y lecciones completadas entre sesiones. Si por algún
   motivo no está disponible, cae de forma segura a memoria (se pierde al
   cerrar, pero la app sigue funcionando).
   ========================================================================= */
const STORAGE_KEY = 'bioquest-progress-v1';
const Store = {
  data: {},
  get(k, fallback){ return k in this.data ? this.data[k] : fallback; },
  set(k, v){ this.data[k] = v; this.persist(); },
  async persist(){
    try{ if (window.storage) await window.storage.set(STORAGE_KEY, JSON.stringify(this.data), false); }
    catch(e){ console.warn('No se pudo guardar el progreso', e); }
  },
  async load(){
    try{
      if (window.storage){
        const r = await window.storage.get(STORAGE_KEY, false);
        if (r && r.value) this.data = JSON.parse(r.value);
      }
    }catch(e){ /* todavía no hay progreso guardado */ }
  }
};

/* ---------------------------- CONTENIDO ---------------------------- */
const UNITS = [
  {
    id:'bases', title:'Bases de la Biología', sub:'Ciencia y funciones vitales', theme:'leaf', icon:'flask',
    levels:[
      { title:'Método científico',
        teach:[
          { heading:'El método científico', body:'Es el camino ordenado que sigue la ciencia para producir conocimiento confiable: observar un fenómeno, buscar antecedentes, formular una hipótesis comprobable, diseñar un experimento, analizar los datos y sacar conclusiones que aceptan, rechazan o ajustan la hipótesis inicial.' },
          { heading:'Experimentación', body:'Es la etapa más activa del método: poner a prueba la hipótesis con una prueba controlada.', bullets:[
            '<b>Variable independiente:</b> la que el investigador manipula (la causa).',
            '<b>Variable dependiente:</b> la respuesta que se mide (el efecto).',
            '<b>Grupo control:</b> no recibe el tratamiento; permite comparar.',
            '<b>Repeticiones:</b> hacen que el resultado sea confiable.'
          ]},
          { heading:'Modelo científico', body:'No es una etapa del método, sino un producto del conocimiento ya acumulado: una representación simplificada de la realidad (como el modelo de la doble hélice del ADN). Es siempre provisorio: puede modificarse ante nueva evidencia.' }
        ],
        qs:[
          {type:'mc', q:'¿En qué etapa del método se propone una explicación tentativa y comprobable?', opts:['Observación','Formulación de la hipótesis','Diseño experimental','Conclusiones'], a:1},
          {type:'tf', q:'El modelo científico es una etapa del método científico.', a:false, explain:'El modelo es un producto del conocimiento acumulado, no una etapa del método.'},
          {type:'mc', q:'La variable que el investigador manipula deliberadamente es la...', opts:['Dependiente','De control','Independiente','Hipotética'], a:2},
          {type:'mc', q:'¿Cómo se llama el grupo que no recibe el tratamiento?', opts:['Grupo control','Grupo experimental','Grupo dependiente','Grupo piloto'], a:0},
          {type:'tf', q:'Un modelo científico puede modificarse si aparece nueva evidencia.', a:true, explain:'Todo modelo es provisorio y puede ajustarse o reemplazarse.'},
          {type:'fill', q:'La ___ es la variable que responde al cambio y es la que se mide en un experimento.', opts:['variable dependiente','variable independiente','hipótesis','conclusión'], a:0},
          {type:'match', q:'Relacioná cada término con su definición.', pairs:[
            ['Hipótesis','Explicación tentativa y comprobable'],
            ['Variable independiente','La que el investigador manipula'],
            ['Grupo control','No recibe el tratamiento'],
            ['Modelo científico','Representación simplificada y provisoria']
          ]},
        ]
      },
      { title:'Funciones vitales',
        teach:[
          { heading:'Las tres funciones vitales', body:'Todo ser vivo cumple tres funciones básicas para mantenerse con vida y perpetuar su especie: nutrición, relación y reproducción. Otras ideas como el crecimiento o la homeostasis no se cuentan aparte — quedan incluidas dentro de estas tres.' },
          { heading:'Nutrición y relación', body:'La nutrición obtiene materia y energía del medio (incorporación, digestión, absorción, metabolismo, excreción). La relación (o irritabilidad) percibe estímulos y responde a ellos mediante un receptor, un sistema de coordinación y un efector.' },
          { heading:'Reproducción', body:'Genera nuevos individuos y asegura la continuidad de la especie. No es indispensable para el individuo, pero sí para la especie. Puede ser asexual (un solo progenitor) o sexual (fusión de gametas de dos progenitores).' }
        ],
        qs:[
          {type:'mc', q:'¿Cuáles son las tres funciones vitales clásicas?', opts:['Nutrición, relación y reproducción','Crecimiento, digestión y excreción','Respiración, circulación y relación','Nutrición, homeostasis y evolución'], a:0},
          {type:'tf', q:'La reproducción es indispensable para la supervivencia del individuo.', a:false, explain:'Es indispensable para la especie, no para el individuo.'},
          {type:'mc', q:'Percibir estímulos y responder a ellos corresponde a la función de...', opts:['Nutrición','Relación','Reproducción','Digestión'], a:1},
          {type:'mc', q:'La estructura que ejecuta la respuesta a un estímulo se llama...', opts:['Receptor','Efector','Coordinador','Sensor'], a:1},
          {type:'tf', q:'El crecimiento suele contarse como una cuarta función vital, aparte de las tres clásicas.', a:false, explain:'El crecimiento queda incluido dentro de la nutrición, no se cuenta aparte.'},
          {type:'fill', q:'La función que asegura la continuidad de la especie, aunque no sea indispensable para el individuo, es la ___.', opts:['reproducción','nutrición','relación','excreción'], a:0},
          {type:'match', q:'Relacioná cada función con lo que hace.', pairs:[
            ['Nutrición','Obtener materia y energía del medio'],
            ['Relación','Percibir y responder a estímulos'],
            ['Reproducción','Generar nuevos individuos'],
            ['Efector','Ejecuta la respuesta al estímulo']
          ]},
        ]
      },
      { title:'Nutrición autótrofa y heterótrofa',
        teach:[
          { heading:'Autótrofa', body:'Sintetiza su propia materia orgánica a partir de sustancias inorgánicas.', bullets:[
            '<b>Fotoautótrofos:</b> usan luz solar (plantas, algas, cianobacterias).',
            '<b>Quimioautótrofos:</b> usan reacciones químicas inorgánicas, sin luz (bacterias del azufre).'
          ]},
          { heading:'Heterótrofa', body:'Depende de consumir materia orgánica ya elaborada por otros.', bullets:[
            '<b>Holozoica:</b> ingiere partículas o presas (herbívoros, carnívoros, omnívoros).',
            '<b>Saprófita:</b> se nutre de materia orgánica muerta (hongos).',
            '<b>Parásita:</b> vive a expensas de un huésped vivo (ecto- o endoparásito).',
            '<b>Simbiótica:</b> beneficio mutuo entre dos organismos.'
          ]}
        ],
        qs:[
          {type:'mc', q:'Los organismos que obtienen energía de la luz y fijan CO₂ son...', opts:['Quimioautótrofos','Fotoautótrofos','Saprófitos','Holozoicos'], a:1},
