function resetQuizState(){
  state.qIndex = 0; state.hearts = MAX_HEARTS;
  state.selected = null; state.answered = false; state.sessionCorrect = 0;
  state.combo = 0; state.feedbackMsg = ''; state.match = null;
}

function beginQuiz(){
  resetQuizState();
  state.screen = 'lesson';
  render();
}

/* ---------------------------- PRACTICE MODE ---------------------------- */
function startPractice(){
  let pool = [];
  Object.keys(state.completed).forEach(key=>{
    const [u,l] = key.split('-').map(Number);
    const lvl = UNITS[u].levels[l];
    lvl.qs.forEach(q=>{
      pool.push(Object.assign({}, q, { _unit: UNITS[u].title, _level: lvl.title }));
    });
  });
  pool = shuffleArr(pool).slice(0, Math.min(12, pool.length));
  state.practicePool = pool;
  resetQuizState();
  state.hearts = MAX_HEARTS; // shown but not spent in practice
  state.screen = 'practice';
  render();
}

/* ---------------------------- MATCH (RELACIONAR) LOGIC ---------------------------- */
function initMatch(q){
  const terms = shuffleArr(q.pairs.map((p,i)=>({text:p[0], idx:i})));
  const defs = shuffleArr(q.pairs.map((p,i)=>({text:p[1], idx:i})));
  state.match = { terms, defs, matched:new Set(), selTerm:null, selDef:null, wrongPair:null, total:q.pairs.length };
}

function selectMatchTerm(idx){
  if (!state.match || state.match.matched.has(idx)) return;
  state.match.selTerm = idx; state.match.wrongPair = null;
  tryMatch();
  render();
}
function selectMatchDef(idx){
  if (!state.match || state.match.matched.has(idx)) return;
  state.match.selDef = idx; state.match.wrongPair = null;
  tryMatch();
  render();
}
function tryMatch(){
  const m = state.match;
  if (m.selTerm===null || m.selDef===null) return;
  if (m.selTerm === m.selDef){
    m.matched.add(m.selTerm);
    m.selTerm = null; m.selDef = null;
    state.xp += 3; Store.set('xp', state.xp);
    if (m.matched.size >= m.total){
      state.answered = true;
      state.sessionCorrect += 1;
      incrementCombo();
      state.feedbackMsg = CORRECT_MSGS[Math.floor(Math.random()*CORRECT_MSGS.length)];
    }
  } else {
    m.wrongPair = { term:m.selTerm, def:m.selDef };
    m.selTerm = null; m.selDef = null;
    resetCombo();
    setTimeout(()=>{ if (state.match){ state.match.wrongPair = null; render(); } }, 450);
  }
}

function incrementCombo(){ state.combo += 1; }
function resetCombo(){ state.combo = 0; }

/* ---------------------------- QUIZ SCREEN (lesson & practice) ---------------------------- */
function formatQText(text){
  return text.replace('___', '<span class="blank">___</span>');
}

function renderQuizScreen(){
  const practice = state.screen==='practice';
  const qs = activeQuestions();
  const q = qs[state.qIndex];
  const pct = Math.round((state.qIndex/qs.length)*100);
  const lvl = practice ? null : currentLevel();

  let html = `<div class="lesson-header">
    <button class="exit-btn" onclick="exitLesson()" aria-label="Salir">✕</button>
    <div class="progress-track"><div class="progress-fill ${practice?'practice-fill':''}" style="width:${pct}%"></div></div>
    ${practice
      ? `<div class="hearts-mini" style="color:var(--violet-dark)">🔁 ${state.qIndex+1}/${qs.length}</div>`
      : `<div class="hearts-mini">${heartIconSvg()}${state.hearts}</div>`
    }
    ${state.combo>=2 ? `<div class="combo-badge">🔥 ${state.combo}</div>` : ''}
  </div>`;

  html += `<div class="question-wrap">
    <div class="q-kicker">${practice ? (q._unit+' · '+q._level) : (UNITS[state.unitIdx].title+' · '+lvl.title)}</div>`;

  if (q.type==='match'){
    if (!state.match || (state.match.total !== q.pairs.length && !state.answered)) initMatch(q);
    html += `<div class="q-text">${formatQText(q.q)}</div>
      <div class="match-hint">Tocá un término y después su definición para relacionarlos.</div>
      <div class="match-wrap">
        <div class="match-col">${state.match.terms.map(t=>{
          let cls='match-item';
          if (state.match.matched.has(t.idx)) cls+=' matched';
          else if (state.match.selTerm===t.idx) cls+=' selected';
          else if (state.match.wrongPair && state.match.wrongPair.term===t.idx) cls+=' wrong';
          return `<button class="${cls}" ${state.match.matched.has(t.idx)?'disabled':''} onclick="selectMatchTerm(${t.idx})">${t.text}</button>`;
        }).join('')}</div>
        <div class="match-col">${state.match.defs.map(d=>{
          let cls='match-item';
          if (state.match.matched.has(d.idx)) cls+=' matched';
          else if (state.match.selDef===d.idx) cls+=' selected';
          else if (state.match.wrongPair && state.match.wrongPair.def===d.idx) cls+=' wrong';
          return `<button class="${cls}" ${state.match.matched.has(d.idx)?'disabled':''} onclick="selectMatchDef(${d.idx})">${d.text}</button>`;
        }).join('')}</div>
      </div>`;
  } else {
    if (q.type==='fill') html += `<div class="q-type-tag">Completá</div>`;
    html += `<div class="q-text">${formatQText(q.q)}</div>`;
    if (q.type==='mc' || q.type==='fill'){
      html += `<div class="options">`;
      q.opts.forEach((opt,i)=>{ html += optionHtml(i, opt, i===q.a); });
      html += `</div>`;
    } else {
      html += `<div class="tf-row">
        ${optionHtml(true, 'Verdadero', q.a===true)}
        ${optionHtml(false, 'Falso', q.a===false)}
      </div>`;
    }
  }
  html += `</div>`;

  html += actionBarHtml();
  app.innerHTML = html;
}

function optionHtml(value, label, isCorrectValue){
  const letters = {0:'A',1:'B',2:'C',3:'D', true:'V', false:'F'};
  let cls = 'option';
  let disabled = '';
  if (state.answered){
    disabled = 'disabled';
    const selected = state.selected===value;
    if (isCorrectValue) cls += ' correct';
    else if (selected) cls += ' wrong';
  } else if (state.selected===value){
    cls += ' selected';
  }
  return `<button class="${cls}" ${disabled} onclick="selectOption(${JSON.stringify(value)})">
    <span class="letter">${letters[value]}</span><span>${label}</span>
  </button>`;
}

function selectOption(value){
  if (state.answered) return;
  state.selected = value;
  render();
}

function actionBarHtml(){
  const practice = state.screen==='practice';
  const qs = activeQuestions();
  const q = qs[state.qIndex];

  if (q.type==='match'){
    if (!state.answered){
      return `<div class="action-bar"><button class="btn-primary" disabled>Relacioná todos los pares</button></div>`;
    }
    return `<div class="action-bar state-correct">
      <div class="feedback-line correct">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6 9 17l-5-5"/></svg> ${state.feedbackMsg||'¡Todo relacionado!'}
        ${state.combo>=2 ? `<span class="mini-combo">🔥 Racha de ${state.combo}</span>` : ''}
      </div>
      <button class="btn-primary ready ${practice?'practice-state':''}" onclick="nextQuestion()">Continuar</button>
    </div>`;
  }

  if (!state.answered){
    const ready = state.selected!==null;
    return `<div class="action-bar">
      <button class="btn-primary ${ready?(practice?'ready practice-state':'ready'):''}" ${ready?'':'disabled'} onclick="checkAnswer()">Comprobar</button>
    </div>`;
  }
  const correct = state.selected === q.a;
  return `<div class="action-bar ${correct?'state-correct':'state-wrong'}">
    <div class="feedback-line ${correct?'correct':'wrong'}">
      ${correct
        ? `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M20 6 9 17l-5-5"/></svg> ${state.feedbackMsg||'¡Correcto!'}`
        : `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M18 6 6 18M6 6l12 12"/></svg> Respuesta incorrecta`
      }
      ${correct && state.combo>=2 ? `<span class="mini-combo">🔥 Racha de ${state.combo}</span>` : ''}
    </div>
    ${q.explain ? `<p class="feedback-explain">${q.explain}</p>` : ''}
    <button class="btn-primary ready ${correct?(practice?'practice-state':''):'wrong-state'}" onclick="nextQuestion()">Continuar</button>
  </div>`;
}

function checkAnswer(){
  if (state.selected===null || state.answered) return;
  const practice = state.screen==='practice';
  const qs = activeQuestions();
  const q = qs[state.qIndex];
  state.answered = true;
  if (state.selected === q.a){
    state.xp += practice ? 5 : 10;
    Store.set('xp', state.xp);
    state.sessionCorrect += 1;
    incrementCombo();
    state.feedbackMsg = CORRECT_MSGS[Math.floor(Math.random()*CORRECT_MSGS.length)];
  } else {
    resetCombo();
    if (!practice) state.hearts -= 1;
  }
  render();

  if (!practice && state.hearts <= 0){
    setTimeout(()=>{ state.screen='gameover'; render(); }, 900);
  }
}

function nextQuestion(){
  const practice = state.screen==='practice';
  const qs = activeQuestions();
  if (!practice && state.hearts<=0) return;
  state.qIndex += 1;
  state.selected = null;
  state.answered = false;
  state.match = null;
  state.feedbackMsg = '';

  if (state.qIndex >= qs.length){
    if (practice){
      state.screen = 'practiceSummary';
    } else {
      const key = `${state.unitIdx}-${state.levelIdx}`;
      if (!state.completed[key]){
        state.completed[key] = true;
        Store.set('completed', state.completed);
        state.streak += 1;
        Store.set('streak', state.streak);
      }
      state.screen = 'summary';
    }
  }
  render();
}

function exitLesson(){
  state.screen = 'home';
  render();
}

function renderSummary(){
  const lvl = currentLevel();
  const total = lvl.qs.length;
  app.innerHTML = `<div class="center-screen">
    <svg class="badge" viewBox="0 0 24 24" fill="none" stroke="var(--leaf)" stroke-width="1.3">
      <circle cx="12" cy="12" r="9" fill="var(--leaf-pale)"/>
      <path d="M8 12.5l2.7 2.7L16 9.5" stroke="var(--leaf)" stroke-width="2"/>
    </svg>
    <h1>¡Lección completa!</h1>
    <p>Terminaste "${lvl.title}" de ${UNITS[state.unitIdx].title}.</p>
    <div class="summary-stats">
      <div class="summary-stat"><div class="num">${state.sessionCorrect}/${total}</div><div class="lbl">Correctas</div></div>
      <div class="summary-stat"><div class="num">+${state.sessionCorrect*10}</div><div class="lbl">XP ganado</div></div>
      <div class="summary-stat"><div class="num">${state.streak}</div><div class="lbl">Racha</div></div>
    </div>
    <button class="wide-btn" onclick="backToHome()">Continuar</button>
    <button class="wide-btn secondary" onclick="startPractice()">Repasar por repetición 🔁</button>
  </div>`;
}

function renderPracticeSummary(){
  const total = state.practicePool.length;
  app.innerHTML = `<div class="center-screen">
    <svg class="badge" viewBox="0 0 24 24" fill="none" stroke="var(--violet)" stroke-width="1.3">
      <circle cx="12" cy="12" r="9" fill="var(--violet-pale)"/>
      <path d="M8 12.5l2.7 2.7L16 9.5" stroke="var(--violet)" stroke-width="2"/>
    </svg>
    <h1>¡Repaso completo!</h1>
    <p>Repasaste ${total} preguntas de todo lo que ya aprendiste. La repetición es la clave para que no se te olvide.</p>
    <div class="summary-stats">
      <div class="summary-stat"><div class="num">${state.sessionCorrect}/${total}</div><div class="lbl">Correctas</div></div>
      <div class="summary-stat"><div class="num">+${state.sessionCorrect*5}</div><div class="lbl">XP ganado</div></div>
    </div>
    <button class="wide-btn" onclick="startPractice()">Repasar de nuevo</button>
    <button class="wide-btn secondary" onclick="backToHome()">Volver al mapa</button>
  </div>`;
}

function renderGameOver(){
  app.innerHTML = `<div class="center-screen">
    <svg class="badge" viewBox="0 0 24 24" fill="none" stroke="var(--coral)" stroke-width="1.3">
      <circle cx="12" cy="12" r="9" fill="var(--coral-pale)"/>
      <path d="M9 9l6 6M15 9l-6 6" stroke="var(--coral)" stroke-width="2"/>
    </svg>
    <h1>Te quedaste sin vidas</h1>
    <p>No pasa nada — repasá la lección "${currentLevel().title}" y volvé a intentarlo.</p>
    <button class="wide-btn" onclick="retryLevel()">Reintentar lección</button>
    <button class="wide-btn secondary" onclick="backToHome()">Volver al mapa</button>
  </div>`;
}

function retryLevel(){
  resetQuizState();
  state.screen = 'lesson';
  render();
}

function backToHome(){
  state.screen = 'home';
  render();
}

/* ---------------------------- INIT ---------------------------- */
(async function init(){
  await Store.load();
  state.xp = Store.get('xp', 0);
  state.streak = Store.get('streak', 0);
  state.completed = Store.get('completed', {});
  render();
})();
</script>
</body>
</html>
