function renderHome(){
  let html = topBar();
  html += `<div class="home-header">
    <div class="eyebrow">BioQuest</div>
    <h1>Explorá la Biología</h1>
    <p class="lead">Un sendero con lo que vimos en la cursada: método científico, célula, fotosíntesis, fisiología animal, el planeta Tierra, evolución y ecología.</p>
  </div>`;

  if (hasAnyCompleted()){
    html += `<div class="practice-card">
      <div class="icon-wrap"><svg viewBox="0 0 24 24"><path d="M3 12a9 9 0 1 0 3-6.7M3 4v5h5"/></svg></div>
      <div class="txt"><h3>Modo Repaso</h3><p>Practicá por repetición todo lo que ya aprendiste. Sin corazones, sin límite.</p></div>
      <button onclick="startPractice()">Repasar</button>
    </div>`;
  } else {
    html += `<div class="practice-locked">Completá tu primera lección para desbloquear el <b>Modo Repaso</b> 🔁</div>`;
  }

  UNITS.forEach((unit, u)=>{
