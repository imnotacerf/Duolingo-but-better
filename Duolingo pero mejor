      <svg viewBox="0 0 24 24" fill="var(--leaf)" stroke="none"><path d="M12 2c1 4-3 5-3 9a3 3 0 0 0 6 0c1 2 1 4-.5 5.5A6 6 0 0 1 4 12c0-4 3-6 3-9 2 1 3 2 3 3 0-1.5.6-3 2-4z"/></svg>
