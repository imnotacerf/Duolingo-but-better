            ${unlocked
              ? `<svg class="icon" viewBox="0 0 24 24">${ICONS[unit.icon]}</svg>`
              : `<svg viewBox="0 0 24 24" width="26" height="26" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>`
