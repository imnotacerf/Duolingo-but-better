function goToLevel(u,l){
  state.unitIdx = u; state.levelIdx = l;
  state.screen = 'teach';
  render();
}

function currentLevel(){ return UNITS[state.unitIdx].levels[state.levelIdx]; }

/* Which set of questions is active right now, depending on screen */
function activeQuestions(){
  return state.screen==='practice' ? state.practicePool : currentLevel().qs;
}

/* ---------------------------- TEACH SCREEN ---------------------------- */
function renderTeach(){
  const lvl = currentLevel();
  let html = `<div class="lesson-header">
    <button class="exit-btn" onclick="exitLesson()" aria-label="Salir">✕</button>
    <div class="teach-heading-line">${UNITS[state.unitIdx].title} · ${lvl.title}</div>
  </div>`;

  html += `<div class="teach-wrap">
    <div class="q-kicker">Aprendé antes de practicar</div>
    <h2 class="teach-title">${lvl.title}</h2>`;

  lvl.teach.forEach(block=>{
    html += `<div class="concept">
      <h3>${block.heading}</h3>
      <p>${block.body}</p>
      ${block.bullets ? `<ul>${block.bullets.map(b=>`<li>${b}</li>`).join('')}</ul>` : ''}
